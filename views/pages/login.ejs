<div id="app">
  <!-- Full-bleed layout: background image + dark card -->
  <div class="relative min-h-[calc(100vh-72px)] flex">

    <!-- Background image (hidden on mobile, shown md+) -->
    <div class="hidden md:block md:flex-1 relative overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=1000&q=80"
        alt="花漾生活"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(10,10,10,0.3), rgba(10,10,10,0.6));"></div>
      <!-- Brand tagline overlay -->
      <div class="absolute bottom-16 left-12">
        <p class="text-lime font-mono text-[10px] tracking-[4px] uppercase mb-3" style="font-family: 'JetBrains Mono', monospace;">— Flower Life</p>
        <h2 class="text-5xl font-semibold italic text-chalk leading-tight" style="font-family: 'Cormorant Garamond', serif;">
          Flowers<br>that speak<br>for you.
        </h2>
      </div>
    </div>

    <!-- Login Card -->
    <div class="w-full md:w-[480px] bg-[#0d0d0d] border-l border-border flex flex-col justify-center px-10 md:px-14 py-16">

      <!-- Brand (mobile only) -->
      <div class="md:hidden text-center mb-10">
        <span class="text-2xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">花漾生活</span>
      </div>

      <!-- Tabs -->
      <div class="flex border-b border-border mb-8">
        <button
          @click="activeTab = 'login'; errors = {}"
          class="flex-1 pb-3 text-[11px] tracking-[2px] uppercase font-medium transition-colors border-b-2 -mb-px"
          :class="activeTab === 'login' ? 'border-lime text-lime' : 'border-transparent text-stone hover:text-chalk'"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          Login
        </button>
        <button
          @click="activeTab = 'register'; errors = {}"
          class="flex-1 pb-3 text-[11px] tracking-[2px] uppercase font-medium transition-colors border-b-2 -mb-px"
          :class="activeTab === 'register' ? 'border-lime text-lime' : 'border-transparent text-stone hover:text-chalk'"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          Register
        </button>
      </div>

      <!-- Greeting -->
      <div class="mb-8">
        <h1 class="text-4xl font-semibold italic text-chalk mb-2" style="font-family: 'Cormorant Garamond', serif;">
          {{ activeTab === 'login' ? '歡迎回來' : '加入我們' }}
        </h1>
        <p class="text-stone text-sm">{{ activeTab === 'login' ? '登入您的帳戶以繼續' : '建立新帳戶開始購物' }}</p>
      </div>

      <!-- Login Form -->
      <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" class="flex flex-col gap-5">
        <div>
          <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">Email</label>
          <input
            v-model="loginForm.email"
            type="email"
            placeholder="your@email.com"
            class="w-full bg-[#111111] border px-4 py-3 text-sm text-chalk placeholder:text-stone/50 focus:outline-none transition-colors"
            :class="errors.email ? 'border-coral' : 'border-border focus:border-stone'"
          />
          <p v-if="errors.email" class="text-coral text-xs mt-1.5">{{ errors.email }}</p>
        </div>

        <div>
          <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">Password</label>
          <input
            v-model="loginForm.password"
            type="password"
            placeholder="••••••••"
            class="w-full bg-[#111111] border px-4 py-3 text-sm text-chalk placeholder:text-stone/50 focus:outline-none transition-colors"
            :class="errors.password ? 'border-coral' : 'border-border focus:border-stone'"
          />
          <p v-if="errors.password" class="text-coral text-xs mt-1.5">{{ errors.password }}</p>
        </div>

        <button
          type="submit"
          :disabled="submitting"
          class="w-full bg-lime text-ink py-3.5 text-[11px] font-bold tracking-[3px] uppercase hover:bg-lime/90 transition-colors disabled:opacity-50 mt-2"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          {{ submitting ? 'Signing in...' : '登入' }}
        </button>
      </form>

      <!-- Register Form -->
      <form v-else @submit.prevent="handleRegister" class="flex flex-col gap-5">
        <div>
          <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">Name</label>
          <input
            v-model="registerForm.name"
            type="text"
            placeholder="您的姓名"
            class="w-full bg-[#111111] border px-4 py-3 text-sm text-chalk placeholder:text-stone/50 focus:outline-none transition-colors"
            :class="errors.name ? 'border-coral' : 'border-border focus:border-stone'"
          />
          <p v-if="errors.name" class="text-coral text-xs mt-1.5">{{ errors.name }}</p>
        </div>

        <div>
          <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">Email</label>
          <input
            v-model="registerForm.email"
            type="email"
            placeholder="your@email.com"
            class="w-full bg-[#111111] border px-4 py-3 text-sm text-chalk placeholder:text-stone/50 focus:outline-none transition-colors"
            :class="errors.email ? 'border-coral' : 'border-border focus:border-stone'"
          />
          <p v-if="errors.email" class="text-coral text-xs mt-1.5">{{ errors.email }}</p>
        </div>

        <div>
          <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">Password</label>
          <input
            v-model="registerForm.password"
            type="password"
            placeholder="至少 6 個字元"
            class="w-full bg-[#111111] border px-4 py-3 text-sm text-chalk placeholder:text-stone/50 focus:outline-none transition-colors"
            :class="errors.password ? 'border-coral' : 'border-border focus:border-stone'"
          />
          <p v-if="errors.password" class="text-coral text-xs mt-1.5">{{ errors.password }}</p>
        </div>

        <button
          type="submit"
          :disabled="submitting"
          class="w-full bg-lime text-ink py-3.5 text-[11px] font-bold tracking-[3px] uppercase hover:bg-lime/90 transition-colors disabled:opacity-50 mt-2"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          {{ submitting ? 'Creating...' : '註冊' }}
        </button>
      </form>
    </div>
  </div>
</div>
