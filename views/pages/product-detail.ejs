<div id="app" data-product-id="<%= productId %>">

  <!-- Loading -->
  <div v-if="loading" class="flex justify-center items-center" style="min-height: 60vh;">
    <div class="w-5 h-5 border-2 border-lime border-t-transparent rounded-full animate-spin"></div>
  </div>

  <!-- Not Found -->
  <div v-else-if="notFound" class="flex flex-col items-center justify-center text-center py-24">
    <p class="text-stone font-mono text-xs tracking-[3px] uppercase mb-4" style="font-family: 'JetBrains Mono', monospace;">404</p>
    <h2 class="text-4xl font-semibold italic text-chalk mb-4" style="font-family: 'Cormorant Garamond', serif;">找不到此商品</h2>
    <a href="/" class="text-lime text-xs font-mono tracking-[2px] uppercase hover:text-lime/70 transition-colors" style="font-family: 'JetBrains Mono', monospace;">← Back to Shop</a>
  </div>

  <!-- Product -->
  <div v-else-if="product">

    <!-- Breadcrumb -->
    <div class="border-b border-border">
      <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14 py-3">
        <p class="text-stone text-[11px] tracking-[1px] font-mono" style="font-family: 'JetBrains Mono', monospace;">
          <a href="/" class="hover:text-chalk transition-colors">Shop</a>
          <span class="mx-2">/</span>
          <span class="text-chalk">{{ product.name }}</span>
        </p>
      </div>
    </div>

    <!-- Main content -->
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14">
      <div class="flex flex-col md:flex-row gap-0">

        <!-- Left: Image column -->
        <div class="md:w-[55%] border-r border-border">
          <div class="relative overflow-hidden" style="height: 680px;">
            <img
              :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=900'"
              :alt="product.name"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Thumbnails row -->
          <div class="flex gap-0.5 border-t border-border">
            <div class="w-20 h-20 overflow-hidden border-r border-border opacity-100">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=200'"
                :alt="product.name"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="w-20 h-20 overflow-hidden border-r border-border opacity-40">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=200'"
                :alt="product.name"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="w-20 h-20 overflow-hidden border-r border-border opacity-40">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=200'"
                :alt="product.name"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>

        <!-- Right: Info column -->
        <div class="md:w-[45%] flex flex-col justify-center px-8 md:px-14 py-14">

          <!-- Name & Price -->
          <h1 class="text-5xl md:text-6xl font-semibold italic text-chalk leading-tight mb-3" style="font-family: 'Cormorant Garamond', serif;">
            {{ product.name }}
          </h1>

          <div class="flex items-center gap-4 mb-6">
            <p class="text-lime text-2xl font-mono" style="font-family: 'JetBrains Mono', monospace;">NT$ {{ product.price.toLocaleString() }}</p>
            <span
              class="text-[10px] font-mono tracking-[2px] uppercase px-2 py-1"
              :class="product.stock > 0 ? 'text-[#88CC00] border border-[#88CC00]/30 bg-[#88CC00]/10' : 'text-coral border border-coral/30 bg-coral/10'"
              style="font-family: 'JetBrains Mono', monospace;"
            >
              {{ product.stock > 0 ? `庫存 ${product.stock} 件` : '已售完' }}
            </span>
          </div>

          <div class="w-12 h-px bg-border mb-6"></div>

          <p class="text-stone text-sm leading-relaxed mb-8">{{ product.description }}</p>

          <!-- Quantity Selector -->
          <div class="flex items-center gap-6 mb-8">
            <span class="text-stone text-[10px] tracking-[2px] uppercase" style="font-family: 'JetBrains Mono', monospace;">QTY</span>
            <div class="flex items-center border border-border">
              <button
                @click="decrease"
                class="w-11 h-11 flex items-center justify-center text-stone hover:text-chalk hover:bg-surface-card transition-colors text-lg"
              >
                −
              </button>
              <span class="w-12 h-11 flex items-center justify-center text-chalk text-sm border-x border-border" style="font-family: 'JetBrains Mono', monospace;">
                {{ quantity }}
              </span>
              <button
                @click="increase"
                class="w-11 h-11 flex items-center justify-center text-stone hover:text-chalk hover:bg-surface-card transition-colors text-lg"
              >
                +
              </button>
            </div>
          </div>

          <!-- CTA -->
          <div class="flex gap-2 mb-10">
            <button
              @click="addToCart"
              :disabled="adding || product.stock <= 0"
              class="flex-1 bg-lime text-ink py-4 text-[11px] font-bold tracking-[3px] uppercase hover:bg-lime/90 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
              style="font-family: 'JetBrains Mono', monospace;"
            >
              {{ product.stock <= 0 ? 'Sold Out' : '加入購物車' }}
            </button>
          </div>

          <!-- Purchase Notes -->
          <div class="border border-border p-6">
            <h3 class="text-[9px] font-mono tracking-[3px] uppercase text-stone mb-4" style="font-family: 'JetBrains Mono', monospace;">購買須知</h3>
            <ul class="flex flex-col gap-2.5">
              <li class="flex items-start gap-3">
                <span class="w-1 h-1 mt-1.5 bg-lime shrink-0"></span>
                <span class="text-stone text-xs">花材依據季節供應，實際花束可能略有差異</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1 h-1 mt-1.5 bg-lime shrink-0"></span>
                <span class="text-stone text-xs">台北市區可享當日配送服務</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1 h-1 mt-1.5 bg-lime shrink-0"></span>
                <span class="text-stone text-xs">消費滿 NT$ 500 享免運優惠</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
