<div id="app">
  <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14 py-12 md:py-16">

    <!-- Page Header -->
    <div class="flex items-end justify-between mb-10 border-b border-border pb-8">
      <div class="flex flex-col gap-1.5">
        <span class="text-lime font-mono text-[10px] tracking-[3px] uppercase" style="font-family: 'JetBrains Mono', monospace;">My Orders</span>
        <h1 class="text-4xl md:text-5xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">我的訂單</h1>
      </div>
    </div>

    <!-- Loading -->
    <div v-if="loading" class="flex justify-center py-16">
      <div class="w-5 h-5 border-2 border-lime border-t-transparent rounded-full animate-spin"></div>
    </div>

    <!-- Empty -->
    <div v-else-if="orders.length === 0" class="flex flex-col items-center justify-center py-24 text-center">
      <p class="text-stone text-sm mb-6">尚無訂單，快去選購喜歡的花束吧。</p>
      <a href="/" class="bg-lime text-ink px-8 py-3 text-[11px] font-bold tracking-[3px] uppercase hover:bg-lime/90 transition-colors" style="font-family: 'JetBrains Mono', monospace;">
        Shop Now
      </a>
    </div>

    <!-- Orders List -->
    <div v-else class="flex flex-col gap-0.5">

      <!-- Table header (desktop) -->
      <div class="hidden md:grid grid-cols-[1fr_auto_auto_auto] gap-8 items-center px-6 py-3 border border-border">
        <span class="text-stone text-[10px] tracking-[2px] uppercase" style="font-family: 'JetBrains Mono', monospace;">訂單編號</span>
        <span class="text-stone text-[10px] tracking-[2px] uppercase w-32 text-right" style="font-family: 'JetBrains Mono', monospace;">金額</span>
        <span class="text-stone text-[10px] tracking-[2px] uppercase w-20 text-center" style="font-family: 'JetBrains Mono', monospace;">狀態</span>
        <span class="w-6"></span>
      </div>

      <!-- Order rows -->
      <a
        v-for="order in orders"
        :key="order.id"
        :href="'/orders/' + order.id"
        class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto_auto] gap-3 md:gap-8 items-center px-6 py-5 border border-border bg-surface-card hover:bg-ink transition-colors group"
      >
        <div>
          <p class="text-chalk text-sm font-mono mb-1" style="font-family: 'JetBrains Mono', monospace;">{{ order.order_no }}</p>
          <p class="text-stone text-xs" style="font-family: 'JetBrains Mono', monospace;">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>

        <p class="text-chalk font-mono text-sm text-right w-32" style="font-family: 'JetBrains Mono', monospace;">
          NT$ {{ order.total_amount.toLocaleString() }}
        </p>

        <div class="w-20 flex justify-center">
          <span
            class="text-[9px] px-2.5 py-1 font-mono tracking-[1px] uppercase"
            :class="{
              'text-[#88CC00] border border-[#88CC00]/30 bg-[#88CC00]/10': order.status === 'paid',
              'text-lime border border-lime/30 bg-lime/5': order.status === 'pending',
              'text-coral border border-coral/30 bg-coral/10': order.status === 'failed'
            }"
            style="font-family: 'JetBrains Mono', monospace;"
          >
            {{ statusMap[order.status]?.label || order.status }}
          </span>
        </div>

        <span class="text-stone group-hover:text-chalk transition-colors text-lg w-6 text-right hidden md:block">&rarr;</span>
      </a>
    </div>

  </div>
</div>
