<div id="app">

  <!-- Hero Banner — 全出血 -->
  <section class="relative w-full overflow-hidden" style="height: 680px;">
    <img
      src="https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=1440&q=80"
      alt="花束"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <!-- 漸層遮罩 -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(10,10,10,0.85) 40%, rgba(10,10,10,0.2));"></div>

    <!-- 內容 -->
    <div class="relative h-full w-full max-w-[1440px] mx-auto px-6 md:px-14 flex flex-col justify-center">
      <p class="text-lime font-mono text-[10px] tracking-[4px] uppercase mb-4" style="font-family: 'JetBrains Mono', monospace;">— Where Flowers Tell Stories</p>
      <h1 class="text-5xl md:text-7xl font-semibold italic text-chalk leading-[1.1] mb-6 max-w-lg" style="font-family: 'Cormorant Garamond', serif;">
        讓花裝點<br>生活每一刻
      </h1>
      <p class="text-stone text-sm md:text-base leading-relaxed mb-10 max-w-sm">
        精選當季鮮花，由專業花藝師手工包裝。<br>每一束花都傳遞著溫暖與祝福。
      </p>
      <div class="flex items-center gap-4">
        <a href="#products" class="bg-lime text-ink px-8 py-3 text-[11px] font-bold tracking-[3px] uppercase hover:bg-lime/90 transition-colors" style="font-family: 'JetBrains Mono', monospace;">
          Shop Now
        </a>
        <a href="#story" class="border border-chalk/30 text-chalk px-8 py-3 text-[11px] tracking-[3px] uppercase hover:border-chalk/60 transition-colors" style="font-family: 'JetBrains Mono', monospace;">
          Our Story
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y border-border">
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14">
      <div class="flex flex-col md:flex-row items-center justify-between py-6 gap-6">
        <div class="flex items-center gap-3 text-center md:text-left">
          <span class="text-2xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">1,200+</span>
          <span class="text-stone text-xs tracking-wider" style="font-family: 'JetBrains Mono', monospace;">Happy Customers</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-border"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">50+</span>
          <span class="text-stone text-xs tracking-wider" style="font-family: 'JetBrains Mono', monospace;">Floral Varieties</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-border"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">5 Years</span>
          <span class="text-stone text-xs tracking-wider" style="font-family: 'JetBrains Mono', monospace;">Of Excellence</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-border"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">Same Day</span>
          <span class="text-stone text-xs tracking-wider" style="font-family: 'JetBrains Mono', monospace;">Delivery in Taipei</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-16 md:py-20">
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14">

      <!-- Section header -->
      <div class="flex items-end justify-between mb-10">
        <div class="flex flex-col gap-1.5">
          <span class="text-lime font-mono text-[10px] tracking-[3px] uppercase" style="font-family: 'JetBrains Mono', monospace;">Featured</span>
          <h2 class="text-4xl md:text-5xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">精選推薦</h2>
        </div>
        <a href="#products" class="hidden md:flex items-center gap-2 text-stone text-[11px] tracking-[2px] uppercase border border-border-light px-4 py-2 hover:border-stone hover:text-chalk transition-colors" style="font-family: 'JetBrains Mono', monospace;">
          View All &rarr;
        </a>
      </div>

      <!-- Featured grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0.5">
        <div
          v-for="(product, idx) in products.slice(0, 4)"
          :key="product.id"
          class="relative group overflow-hidden cursor-pointer"
          style="height: 360px;"
          @click="goToProduct(product.id)"
        >
          <img
            :src="product.image_url || featuredImages[idx % 4]"
            :alt="product.name"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <!-- overlay -->
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 55%);"></div>
          <!-- NEW tag -->
          <span class="absolute top-3 left-3 bg-lime text-ink text-[9px] font-bold tracking-[2px] uppercase px-2.5 py-1" style="font-family: 'JetBrains Mono', monospace;">NEW</span>
          <!-- Info -->
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <h3 class="text-chalk font-semibold italic text-lg leading-tight mb-1 truncate" style="font-family: 'Cormorant Garamond', serif;">{{ product.name }}</h3>
            <p class="text-lime text-[11px] font-mono" style="font-family: 'JetBrains Mono', monospace;">NT$ {{ product.price.toLocaleString() }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Story -->
  <section id="story" class="border-y border-border">
    <div class="flex flex-col md:flex-row" style="min-height: 520px;">
      <div class="md:w-1/2 relative overflow-hidden" style="min-height: 300px;">
        <img
          src="https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=800"
          alt="花藝師"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>
      <div class="md:w-1/2 bg-ink-soft flex flex-col justify-center px-8 md:px-16 py-14 md:py-20">
        <span class="text-lime font-mono text-[10px] tracking-[3px] uppercase mb-4" style="font-family: 'JetBrains Mono', monospace;">Our Story</span>
        <h2 class="text-4xl md:text-5xl font-semibold italic text-chalk leading-tight mb-6" style="font-family: 'Cormorant Garamond', serif;">
          專心，<br>做好一束花的感動
        </h2>
        <p class="text-stone text-sm leading-relaxed mb-6">
          花漾生活成立於 2020 年，我們相信每一朵花都有自己的故事。透過專業花藝師的巧手，將大自然的美好帶進您的日常生活中。
        </p>
        <p class="text-chalk/60 text-sm italic" style="font-family: 'Cormorant Garamond', serif;">
          「每一束花，都是一份用心的禮物。」
        </p>
      </div>
    </div>
  </section>

  <!-- All Products Grid -->
  <section id="products" class="py-16 md:py-20">
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14">

      <!-- Section header -->
      <div class="flex flex-col gap-1.5 mb-10">
        <span class="text-lime font-mono text-[10px] tracking-[3px] uppercase" style="font-family: 'JetBrains Mono', monospace;">All Flowers</span>
        <h2 class="text-4xl md:text-5xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">花卉精選</h2>
        <p class="text-stone text-sm mt-1">找到屬於您的那束花</p>
      </div>

      <div v-if="loading" class="flex justify-center py-16">
        <div class="w-6 h-6 border-2 border-lime border-t-transparent rounded-full animate-spin"></div>
      </div>

      <template v-else>
        <div v-if="products.length === 0" class="text-center py-16">
          <p class="text-stone text-sm">目前沒有商品，請稍後再來。</p>
        </div>

        <div v-else class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-0.5">
          <div
            v-for="product in products"
            :key="product.id"
            @click="goToProduct(product.id)"
            class="relative group overflow-hidden cursor-pointer bg-surface-card"
          >
            <div class="aspect-square overflow-hidden">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=600'"
                :alt="product.name"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
            </div>
            <div class="p-5 border-t border-border flex items-end justify-between">
              <div>
                <h3 class="text-chalk font-semibold italic text-lg leading-tight mb-1" style="font-family: 'Cormorant Garamond', serif;">{{ product.name }}</h3>
                <p class="text-lime text-[11px] font-mono" style="font-family: 'JetBrains Mono', monospace;">NT$ {{ product.price.toLocaleString() }}</p>
              </div>
              <button
                @click.stop="addToCart(product)"
                :disabled="product._adding || product.stock <= 0"
                class="bg-lime text-ink text-[10px] font-bold tracking-[2px] uppercase px-4 py-2 hover:bg-lime/90 transition-colors disabled:opacity-40 disabled:cursor-not-allowed shrink-0"
                style="font-family: 'JetBrains Mono', monospace;"
              >
                {{ product.stock <= 0 ? 'Sold Out' : 'Add' }}
              </button>
            </div>
          </div>
        </div>

        <!-- Pagination -->
        <div v-if="pagination.totalPages > 1" class="flex justify-center gap-1 mt-10">
          <button
            v-for="p in pagination.totalPages"
            :key="p"
            @click="loadProducts(p)"
            class="w-9 h-9 text-[11px] font-mono transition-colors border"
            :class="p === pagination.page ? 'bg-lime text-ink border-lime' : 'border-border text-stone hover:border-stone hover:text-chalk'"
            style="font-family: 'JetBrains Mono', monospace;"
          >
            {{ p }}
          </button>
        </div>
      </template>
    </div>
  </section>

  <!-- Customer Testimonials -->
  <section class="py-16 md:py-20 border-t border-border bg-ink-soft">
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14">
      <div class="flex flex-col gap-1.5 mb-10">
        <span class="text-lime font-mono text-[10px] tracking-[3px] uppercase" style="font-family: 'JetBrains Mono', monospace;">Reviews</span>
        <h2 class="text-4xl md:text-5xl font-semibold italic text-chalk" style="font-family: 'Cormorant Garamond', serif;">顧客好評</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0.5">
        <div class="bg-surface-card border border-border p-8">
          <p class="text-lime font-mono text-xs tracking-widest mb-4" style="font-family: 'JetBrains Mono', monospace;">★★★★★</p>
          <p class="text-chalk/80 text-sm leading-relaxed mb-6">「花束非常漂亮，包裝精緻，送給媽媽她超開心的！配送也很準時。」</p>
          <p class="text-stone text-xs" style="font-family: 'JetBrains Mono', monospace;">— 小美</p>
        </div>
        <div class="bg-surface-card border border-border p-8">
          <p class="text-lime font-mono text-xs tracking-widest mb-4" style="font-family: 'JetBrains Mono', monospace;">★★★★★</p>
          <p class="text-chalk/80 text-sm leading-relaxed mb-6">「第二次購買了，品質一如既往的好。花材新鮮，整體搭配很有美感。」</p>
          <p class="text-stone text-xs" style="font-family: 'JetBrains Mono', monospace;">— 阿明</p>
        </div>
        <div class="bg-surface-card border border-border p-8">
          <p class="text-lime font-mono text-xs tracking-widest mb-4" style="font-family: 'JetBrains Mono', monospace;">★★★★★</p>
          <p class="text-chalk/80 text-sm leading-relaxed mb-6">「女朋友收到花束超感動！會再回購的，推薦給大家！」</p>
          <p class="text-stone text-xs" style="font-family: 'JetBrains Mono', monospace;">— 大衛</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Features -->
  <section class="border-t border-border">
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-border">
        <div class="flex items-start gap-4 py-10 md:px-10 md:first:pl-0 md:last:pr-0">
          <span class="text-lime font-mono text-xs tracking-widest mt-0.5" style="font-family: 'JetBrains Mono', monospace;">01</span>
          <div>
            <h3 class="text-chalk font-medium mb-1 text-sm">快速配送</h3>
            <p class="text-stone text-xs leading-relaxed">台北市區享當日配送服務</p>
          </div>
        </div>
        <div class="flex items-start gap-4 py-10 md:px-10">
          <span class="text-lime font-mono text-xs tracking-widest mt-0.5" style="font-family: 'JetBrains Mono', monospace;">02</span>
          <div>
            <h3 class="text-chalk font-medium mb-1 text-sm">精美包裝</h3>
            <p class="text-stone text-xs leading-relaxed">每束花都經過專業花藝師精心包裝</p>
          </div>
        </div>
        <div class="flex items-start gap-4 py-10 md:px-10">
          <span class="text-lime font-mono text-xs tracking-widest mt-0.5" style="font-family: 'JetBrains Mono', monospace;">03</span>
          <div>
            <h3 class="text-chalk font-medium mb-1 text-sm">滿額免運</h3>
            <p class="text-stone text-xs leading-relaxed">消費滿 NT$ 500 即享免運優惠</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</div>
