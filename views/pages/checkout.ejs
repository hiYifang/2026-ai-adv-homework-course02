<div id="app">

  <!-- Step Bar -->
  <div class="border-b border-border bg-[#0a0a0a]">
    <div class="w-full max-w-[1440px] mx-auto px-6 md:px-14 py-4 flex items-center justify-center gap-0">

      <!-- Step 1: Cart (done) -->
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded-full bg-lime flex items-center justify-center shrink-0">
          <span class="text-ink text-[9px] font-bold" style="font-family: 'JetBrains Mono', monospace;">✓</span>
        </div>
        <span class="text-chalk text-[10px] tracking-[1px] font-mono" style="font-family: 'JetBrains Mono', monospace;">購物車</span>
      </div>

      <div class="w-10 md:w-16 h-px bg-lime mx-3"></div>

      <!-- Step 2: Info (active) -->
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded-full bg-lime flex items-center justify-center shrink-0">
          <span class="text-ink text-[9px] font-bold" style="font-family: 'JetBrains Mono', monospace;">✓</span>
        </div>
        <span class="text-chalk text-[10px] tracking-[1px] font-mono" style="font-family: 'JetBrains Mono', monospace;">收件資訊</span>
      </div>

      <div class="w-10 md:w-16 h-px bg-border mx-3"></div>

      <!-- Step 3: Payment (pending) -->
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded-full border border-border-light bg-surface-card flex items-center justify-center shrink-0">
          <span class="text-stone text-[9px] font-bold" style="font-family: 'JetBrains Mono', monospace;">3</span>
        </div>
        <span class="text-stone text-[10px] tracking-[1px] font-mono" style="font-family: 'JetBrains Mono', monospace;">付款</span>
      </div>
    </div>
  </div>

  <!-- Loading -->
  <div v-if="loading" class="flex justify-center items-center" style="min-height: 50vh;">
    <div class="w-5 h-5 border-2 border-lime border-t-transparent rounded-full animate-spin"></div>
  </div>

  <!-- Content -->
  <div v-else class="w-full max-w-[1440px] mx-auto">
    <div class="flex flex-col lg:flex-row gap-0.5 min-h-[70vh]">

      <!-- Left: Form -->
      <div class="lg:flex-1 border-r border-border px-6 md:px-14 py-12">
        <div class="max-w-lg">
          <h1 class="text-4xl md:text-5xl font-semibold italic text-chalk mb-8" style="font-family: 'Cormorant Garamond', serif;">收件資訊</h1>

          <div class="flex flex-col gap-6">
            <div>
              <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">收件人姓名</label>
              <input
                v-model="form.recipientName"
                type="text"
                placeholder="請輸入收件人姓名"
                class="w-full bg-surface-card border px-4 py-3 text-sm text-chalk placeholder:text-stone/40 focus:outline-none transition-colors"
                :class="errors.recipientName ? 'border-coral' : 'border-border focus:border-stone'"
              />
              <p v-if="errors.recipientName" class="text-coral text-xs mt-1.5">{{ errors.recipientName }}</p>
            </div>

            <div>
              <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">Email</label>
              <input
                v-model="form.recipientEmail"
                type="email"
                placeholder="your@email.com"
                class="w-full bg-surface-card border px-4 py-3 text-sm text-chalk placeholder:text-stone/40 focus:outline-none transition-colors"
                :class="errors.recipientEmail ? 'border-coral' : 'border-border focus:border-stone'"
              />
              <p v-if="errors.recipientEmail" class="text-coral text-xs mt-1.5">{{ errors.recipientEmail }}</p>
            </div>

            <div>
              <label class="block text-[10px] tracking-[2px] uppercase text-stone mb-2" style="font-family: 'JetBrains Mono', monospace;">收件地址</label>
              <input
                v-model="form.recipientAddress"
                type="text"
                placeholder="請輸入完整收件地址"
                class="w-full bg-surface-card border px-4 py-3 text-sm text-chalk placeholder:text-stone/40 focus:outline-none transition-colors"
                :class="errors.recipientAddress ? 'border-coral' : 'border-border focus:border-stone'"
              />
              <p v-if="errors.recipientAddress" class="text-coral text-xs mt-1.5">{{ errors.recipientAddress }}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Summary -->
      <div class="lg:w-[420px] shrink-0">
        <div class="bg-[#0f0f0f] border-l border-border h-full px-8 py-12 lg:sticky lg:top-[120px]">

          <h2 class="text-[10px] font-mono tracking-[3px] uppercase text-stone mb-6" style="font-family: 'JetBrains Mono', monospace;">訂單摘要</h2>

          <!-- Items -->
          <div class="flex flex-col gap-3 mb-6 border-b border-border pb-6">
            <div v-for="item in cartItems" :key="item.id" class="flex justify-between items-start gap-4 text-sm">
              <span class="text-stone leading-relaxed">{{ item.product.name }} <span class="text-border-light">×</span> {{ item.quantity }}</span>
              <span class="text-chalk font-mono shrink-0" style="font-family: 'JetBrains Mono', monospace;">NT$ {{ (item.product.price * item.quantity).toLocaleString() }}</span>
            </div>
          </div>

          <!-- Totals -->
          <div class="flex flex-col gap-3 text-sm mb-6 border-b border-border pb-6">
            <div class="flex justify-between">
              <span class="text-stone">商品小計</span>
              <span class="text-chalk font-mono" style="font-family: 'JetBrains Mono', monospace;">NT$ {{ cartTotal.toLocaleString() }}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-stone">運費</span>
              <span class="text-chalk font-mono" style="font-family: 'JetBrains Mono', monospace;">{{ cartTotal >= 500 ? '免運' : 'NT$ 150' }}</span>
            </div>
          </div>

          <div class="flex justify-between items-center mb-8">
            <span class="text-chalk font-medium">總計</span>
            <span class="text-lime text-2xl font-semibold italic" style="font-family: 'Cormorant Garamond', serif;">
              NT$ {{ (cartTotal + (cartTotal >= 500 ? 0 : 150)).toLocaleString() }}
            </span>
          </div>

          <button
            @click="submitOrder"
            :disabled="submitting"
            class="w-full bg-lime text-ink py-4 text-[11px] font-bold tracking-[3px] uppercase hover:bg-lime/90 transition-colors disabled:opacity-50"
            style="font-family: 'JetBrains Mono', monospace;"
          >
            {{ submitting ? '處理中...' : '前往付款' }}
          </button>

          <!-- ECPay note -->
          <p class="text-stone text-[10px] text-center mt-4 leading-relaxed" style="font-family: 'JetBrains Mono', monospace;">
            點擊後將跳轉至綠界科技 ECPay 安全付款頁面
          </p>
          <p class="text-[#444] text-[9px] text-center mt-1 tracking-wider" style="font-family: 'JetBrains Mono', monospace;">
            SSL 加密保護 · 由綠界科技處理付款
          </p>
        </div>
      </div>
    </div>
  </div>

</div>
